# OTel Collector credentials for Splunk Observability Cloud
# Copy this file to deploy/.env (gitignored) and fill in your values.
#
# The Splunk Distribution of the OTel Collector (quay.io/signalfx/splunk-otel-collector)
# validates these at startup — empty values will cause the container to exit.

# Splunk Observability Cloud ingest token
# Get from: Splunk O11y → Settings → Access Tokens
SPLUNK_ACCESS_TOKEN=

# Your Splunk realm (e.g. us0, us1, us2, eu0, eu1, jp0, au0)
SPLUNK_REALM=us1
