# =============================================================================
# Azure OpenAI — Chat
# =============================================================================
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-nano
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# =============================================================================
# Azure OpenAI — Embeddings (may use a different api version)
# =============================================================================
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01

# =============================================================================
# OpenTelemetry
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=crewai-customer-support-ui
OTEL_CONSOLE_OUTPUT=false

# =============================================================================
# CrewAI
# =============================================================================
CREWAI_DISABLE_TELEMETRY=true

# =============================================================================
# GenAI message content capture
# =============================================================================
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# =============================================================================
# GenAI Emitters (optional — enable Splunk emitter if using Splunk O11y)
# =============================================================================
# OTEL_INSTRUMENTATION_GENAI_EMITTERS=span_metric_event,splunk

# =============================================================================
# OTel Collector — Azure Container Instance deployment
# Required by collector/deploy-aci.sh
# =============================================================================
SPLUNK_ACCESS_TOKEN=your-splunk-access-token
SPLUNK_HEC_TOKEN=your-splunk-hec-token
SPLUNK_HEC_URL=https://http-inputs-<realm>.splunkcloud.com:443/services/collector/event
SPLUNK_REALM=us1
RESOURCE_GROUP=your-resource-group
STORAGE_ACCOUNT=your-storage-account
