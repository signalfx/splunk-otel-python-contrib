# ── Standard OpenAI ───────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"                    # default: gpt-4o-mini
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"  # default: text-embedding-3-small

# ── Azure OpenAI (set AZURE_OPENAI_ENDPOINT to activate) ─────
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
# AZURE_OPENAI_API_KEY="..."
# AZURE_OPENAI_API_VERSION="2024-12-01-preview"
# AZURE_CHAT_DEPLOYMENT="gpt-4o-mini"            # deployment name for chat
# AZURE_EMBEDDING_DEPLOYMENT="text-embedding-3-large"  # deployment name for embeddings
# AZURE_EMBEDDING_DIMENSIONS="1536"                    # output dims (default: 1536)

# ── Optional ──────────────────────────────────────────────────
# SSL_CERT_FILE="/path/to/cert.pem"
# REQUESTS_CA_BUNDLE="/path/to/cert.pem"
# POLICY_FORCE_OLD_VERSION=true
