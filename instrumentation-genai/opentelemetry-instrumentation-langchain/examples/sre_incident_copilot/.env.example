# ── OpenTelemetry ──────────────────────────────────────────────────────────────
# OTLP endpoint for traces, metrics, and logs.
# Use http://localhost:4317 for a local OTel Collector (gRPC).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Service name shown in APM.
OTEL_SERVICE_NAME=sre-incident-copilot

# opentelemetry-instrument defaults to the generic "otlp" entry point which
# may not be registered in all venvs.  Set these explicitly so that both the
# main process AND MCP server subprocesses use the gRPC exporter.
OTEL_TRACES_EXPORTER=otlp_proto_grpc
OTEL_METRICS_EXPORTER=otlp_proto_grpc

# How often metrics are flushed (ms).  5 s is convenient for demos.
OTEL_METRIC_EXPORT_INTERVAL=5000
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=delta

# Capture LLM message content in spans.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# Emitter selection: "span" (traces only) | "span_metric" (traces + metrics).
OTEL_INSTRUMENTATION_GENAI_EMITTERS=span_metric

# ── LLM provider — choose ONE block ───────────────────────────────────────────
# OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_BASE_URL=https://your-resource.cognitiveservices.azure.com/openai/v1/
# OPENAI_MODEL=gpt-4o-mini

# ── MCP server subprocess options ─────────────────────────────────────────────
# Set to "true" to wrap MCP server subprocesses with opentelemetry-instrument.
SRE_COPILOT_MCP_USE_OTEL_WRAPPER=true
